import Foundation

/// Abstract base for the ways Elo can detect a text selection.
///
/// A concrete listener (e.g. mouse-drag or hotkey) observes some system input,
/// reads the resulting selection, and calls `emit(_:)`. The base forwards that
/// to `onSelection`, the single handler that ultimately shows the overlay.
///
/// Swift has no first-class abstract classes, so `start()`/`stop()` use
/// `fatalError` to enforce that subclasses override them.
class SelectionListener {
    /// Handler invoked (on the main thread) whenever a selection is detected.
    /// Wired up by `AppDelegate` to show the overlay.
    var onSelection: ((SelectionResult) -> Void)?

    init(onSelection: ((SelectionResult) -> Void)? = nil) {
        self.onSelection = onSelection
    }

    /// Begin observing. Subclasses must override.
    func start() {
        fatalError("\(type(of: self)) must override start()")
    }

    /// Stop observing. Subclasses must override.
    func stop() {
        fatalError("\(type(of: self)) must override stop()")
    }

    /// Subclasses call this when they have a selection to surface.
    /// Always delivers on the main thread.
    func emit(_ selection: SelectionResult) {
        if Thread.isMainThread {
            onSelection?(selection)
        } else {
            DispatchQueue.main.async { [weak self] in self?.onSelection?(selection) }
        }
    }
}

