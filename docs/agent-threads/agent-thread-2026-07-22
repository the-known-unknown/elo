import AppKit
import ApplicationServices

/// Thin wrapper around the macOS TCC Accessibility permission.
///
/// Elo needs this permission to read selected text (Accessibility API) and to
/// synthesize the ⌘C keystroke used by the clipboard fallback. The prompt is
/// only shown when the permission is actually missing — if it's already granted
/// we stay silent.
final class AccessibilityManager {
    static let shared = AccessibilityManager()
    private init() {}

    /// Whether the current process is trusted for Accessibility right now.
    var isTrusted: Bool { AXIsProcessTrusted() }

    /// Prompts the user (opening System Settings) only if not already trusted.
    /// Returns the current trust state. Safe to call repeatedly.
    @discardableResult
    func requestAccessIfNeeded() -> Bool {
        guard !isTrusted else { return true }
        let options =
            [kAXTrustedCheckOptionPrompt.takeUnretainedValue() as String: true] as CFDictionary
        return AXIsProcessTrustedWithOptions(options)
    }
}

