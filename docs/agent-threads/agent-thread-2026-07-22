import AppKit
import ApplicationServices

/// Observable wrapper around the macOS Accessibility (TCC) permission.
///
/// `isTrusted` is live OS state, not a saved setting. macOS does NOT notify us
/// when the user flips the toggle in System Settings, so call `refresh()` at
/// opportune moments (e.g. when the Settings window becomes active).
final class AccessibilityManager: ObservableObject {
    static let shared = AccessibilityManager()

    @Published private(set) var isTrusted: Bool

    private init() {
        isTrusted = AXIsProcessTrusted()
    }

    /// Re-reads the current trust state.
    func refresh() {
        isTrusted = AXIsProcessTrusted()
    }

    /// Prompts the user (opening System Settings) if not already trusted.
    func requestAccess() {
        guard !isTrusted else { return }
        let options =
            [kAXTrustedCheckOptionPrompt.takeUnretainedValue() as String: true] as CFDictionary
        isTrusted = AXIsProcessTrustedWithOptions(options)
    }
}

