import AppKit
import SwiftUI

/// A borderless, non-activating floating panel that hosts the SwiftUI menu.
///
/// `.nonactivatingPanel` is the key trait: the panel can be clicked without
/// activating Elo or stealing focus from the app the user is writing in, so the
/// underlying text selection is preserved.
final class OverlayPanel: NSPanel {
    private let menuSize = NSSize(width: 230, height: 92)

    init(onAction: @escaping (MenuAction) -> Void) {
        super.init(contentRect: NSRect(origin: .zero, size: menuSize),
                   styleMask: [.nonactivatingPanel, .borderless],
                   backing: .buffered,
                   defer: false)

        isFloatingPanel = true
        level = .statusBar
        backgroundColor = .clear
        isOpaque = false
        hasShadow = true
        hidesOnDeactivate = false
        isMovableByWindowBackground = false
        collectionBehavior = [.canJoinAllSpaces, .fullScreenAuxiliary, .stationary]

        let hosting = NSHostingView(rootView: OverlayMenuView(onAction: onAction))
        hosting.frame = NSRect(origin: .zero, size: menuSize)
        hosting.autoresizingMask = [.width, .height]
        contentView = hosting
    }

    override var canBecomeKey: Bool { false }
    override var canBecomeMain: Bool { false }

    /// Positions the panel adjacent to the selection (preferred) or the mouse.
    func position(for selection: SelectionResult) {
        let origin: NSPoint
        if let rect = selection.screenRect {
            origin = originBesideSelection(rect)
        } else {
            let mouse = selection.mouseLocation
            origin = NSPoint(x: mouse.x + 8, y: mouse.y - menuSize.height - 8)
        }
        setFrameOrigin(clamp(origin))
    }

    /// Converts an Accessibility rect (top-left origin, global) into an AppKit
    /// origin (bottom-left origin) placing the panel just to the right of the
    /// selection, top-aligned with it.
    private func originBesideSelection(_ rect: CGRect) -> NSPoint {
        let primaryHeight = NSScreen.screens.first?.frame.height ?? rect.maxY
        let selectionTopInAppKit = primaryHeight - rect.minY
        return NSPoint(x: rect.maxX + 8, y: selectionTopInAppKit - menuSize.height)
    }

    /// Keeps the panel fully on whichever screen contains its origin.
    private func clamp(_ origin: NSPoint) -> NSPoint {
        let screen = NSScreen.screens.first { $0.frame.contains(origin) }
            ?? NSScreen.main
            ?? NSScreen.screens.first
        guard let frame = screen?.visibleFrame else { return origin }

        var point = origin
        point.x = min(max(point.x, frame.minX), frame.maxX - menuSize.width)
        point.y = min(max(point.y, frame.minY), frame.maxY - menuSize.height)
        return point
    }
}

