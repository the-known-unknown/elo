import AppKit
import ApplicationServices

/// Thin wrapper around the macOS TCC Accessibility permission.
///
/// Elo cannot read selected text or synthesize keystrokes without this
/// permission, so the app guides the user to grant it (System Settings ->
/// Privacy & Security -> Accessibility).
final class AccessibilityManager {
    static let shared = AccessibilityManager()
    private init() {}

    /// Whether the current process is trusted for Accessibility right now.
    var isTrusted: Bool { AXIsProcessTrusted() }

    /// Checks trust and, when `prompt` is true and trust is missing, asks macOS
    /// to show the standard "open System Settings" prompt.
    @discardableResult
    func ensureTrusted(prompt: Bool) -> Bool {
        let options = [kAXTrustedCheckOptionPrompt.takeUnretainedValue() as String: prompt] as CFDictionary
        return AXIsProcessTrustedWithOptions(options)
    }
}

