import Combine
import Foundation

/// The single source of truth for settings.
///
/// UI binds two-way to `settings`; changes auto-save (debounced) to disk. Other
/// parts of the app subscribe to *slices* via the granular publishers below, so
/// e.g. editing a shortcut's prompt never wakes up an AI-models consumer. The
/// `removeDuplicates()` + `Equatable` models are what make that decoupling work.
final class SettingsStore: ObservableObject {
    @Published var settings: Settings

    private let persistence: SettingsPersisting
    private var saveCancellable: AnyCancellable?

    init(persistence: SettingsPersisting = FileSettingsPersistence()) {
        self.persistence = persistence
        self.settings = persistence.load()

        // Auto-save on change, debounced so typing doesn't hammer the disk.
        saveCancellable =
            $settings
            .dropFirst()
            .debounce(for: .milliseconds(500), scheduler: RunLoop.main)
            .sink { [persistence] settings in persistence.save(settings) }
    }

    /// Where the settings file lives (for "Reveal in Finder" etc.).
    var fileURL: URL? { persistence.fileURL }

    // MARK: - Granular publishers (subscribe to just the slice you care about)

    var shortcutsPublisher: AnyPublisher<[Shortcut], Never> {
        $settings.map(\.application.shortcuts).removeDuplicates().eraseToAnyPublisher()
    }

    var aiModelsPublisher: AnyPublisher<AIModelSettings, Never> {
        $settings.map(\.aiModels).removeDuplicates().eraseToAnyPublisher()
    }
}

