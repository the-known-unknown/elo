import AppKit
import Carbon.HIToolbox

/// Detects the global hotkey (⌃⌘E) and reads the current selection.
///
/// This is the universal manual trigger: it reads via the Accessibility API and,
/// if that yields nothing, falls back to the clipboard (synthesize ⌘C, read,
/// restore). Uses the Carbon `RegisterEventHotKey` API to avoid a third-party
/// dependency for the prototype.
final class HotkeyListener: SelectionListener {
    private var hotKeyRef: EventHotKeyRef?
    private var eventHandlerRef: EventHandlerRef?

    override func start() {
        let hotKeyID = EventHotKeyID(signature: fourCharCode("ELO1"), id: 1)
        var eventType = EventTypeSpec(
            eventClass: OSType(kEventClassKeyboard),
            eventKind: OSType(kEventHotKeyPressed))

        let selfPtr = Unmanaged.passUnretained(self).toOpaque()
        InstallEventHandler(
            GetApplicationEventTarget(),
            { _, _, userData -> OSStatus in
                guard let userData else { return OSStatus(eventNotHandledErr) }
                let listener = Unmanaged<HotkeyListener>.fromOpaque(userData).takeUnretainedValue()
                DispatchQueue.main.async { listener.hotkeyPressed() }
                return noErr
            }, 1, &eventType, selfPtr, &eventHandlerRef)

        let modifiers = UInt32(cmdKey | controlKey)
        let keyCode = UInt32(kVK_ANSI_E)
        let status = RegisterEventHotKey(
            keyCode, modifiers, hotKeyID,
            GetApplicationEventTarget(), 0, &hotKeyRef)
        if status != noErr {
            NSLog("[Elo] Failed to register hotkey (status=\(status)).")
        }
    }

    override func stop() {
        if let hotKeyRef { UnregisterEventHotKey(hotKeyRef) }
        if let eventHandlerRef { RemoveEventHandler(eventHandlerRef) }
        hotKeyRef = nil
        eventHandlerRef = nil
    }

    private func hotkeyPressed() {
        if let result = SelectionReader.shared.readSelection(allowClipboardFallback: true) {
            emit(result)
        } else {
            NSLog("[Elo] Hotkey pressed but no selection could be read.")
        }
    }
}

private func fourCharCode(_ string: String) -> FourCharCode {
    var result: FourCharCode = 0
    for scalar in string.unicodeScalars.prefix(4) {
        result = (result << 8) + FourCharCode(scalar.value & 0xFF)
    }
    return result
}

