import SwiftUI

/// The custom action overlay: a close button and a tappable card per function.
/// Rendered inside a floating panel near the selection when the hotkey fires.
struct ActionMenuView: View {
    let functions: [Function]
    let onSelect: (Function) -> Void
    let onClose: () -> Void

    var body: some View {
        VStack(alignment: .leading, spacing: 12) {
            Button(action: onClose) {
                Image(systemName: "xmark.circle.fill")
                    .symbolRenderingMode(.palette)
                    .foregroundStyle(.white, .red)
                    .font(.system(size: 26))
            }
            .buttonStyle(.plain)
            .padding(.leading, 2)

            if functions.isEmpty {
                Text("No functions configured")
                    .foregroundStyle(.secondary)
                    .frame(maxWidth: .infinity, alignment: .leading)
                    .padding(.horizontal, 20)
                    .padding(.vertical, 18)
                    .background(cardBackground)
            } else {
                ForEach(functions) { function in
                    FunctionCard(
                        label: function.label.isEmpty ? "Untitled" : function.label,
                        action: { onSelect(function) }
                    )
                }
            }
        }
        .padding(10)
        .frame(width: 320)
    }

    private var cardBackground: some View {
        RoundedRectangle(cornerRadius: 12, style: .continuous)
            .fill(Color(nsColor: .textBackgroundColor))
    }
}

/// A single function rendered as a rounded white card (per the design).
private struct FunctionCard: View {
    let label: String
    let action: () -> Void
    @State private var isHovering = false

    var body: some View {
        Button(action: action) {
            Text(label)
                .font(.system(size: 17, weight: .semibold))
                .foregroundStyle(.primary)
                .frame(maxWidth: .infinity, alignment: .leading)
                .padding(.horizontal, 20)
                .padding(.vertical, 18)
                .background(
                    RoundedRectangle(cornerRadius: 12, style: .continuous)
                        .fill(Color(nsColor: .textBackgroundColor))
                )
                .overlay(
                    RoundedRectangle(cornerRadius: 12, style: .continuous)
                        .strokeBorder(Color.primary.opacity(isHovering ? 0.28 : 0.12))
                )
                .shadow(color: .black.opacity(0.12), radius: 4, y: 2)
                .contentShape(Rectangle())
        }
        .buttonStyle(.plain)
        .onHover { isHovering = $0 }
    }
}

