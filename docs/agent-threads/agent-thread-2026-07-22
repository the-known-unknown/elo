import AppKit

/// Owns the lifecycle of the overlay panel: showing it for a selection,
/// dismissing it on outside clicks, and (for now) logging chosen actions.
final class OverlayController {
    private var panel: OverlayPanel?
    private var dismissMonitor: Any?
    private var currentSelection: SelectionResult?

    func show(for selection: SelectionResult) {
        dismiss()
        currentSelection = selection

        let panel = OverlayPanel { [weak self] action in
            self?.handle(action)
        }
        panel.position(for: selection)
        panel.orderFrontRegardless()
        self.panel = panel

        // Global monitor fires only for events outside our app, so clicks on the
        // panel's own buttons won't dismiss it.
        dismissMonitor = NSEvent.addGlobalMonitorForEvents(
            matching: [.leftMouseDown, .rightMouseDown]
        ) { [weak self] _ in
            self?.dismiss()
        }

        NSLog("[Elo] Overlay shown. source=\(selection.source.rawValue) text=\"\(preview(selection.text))\"")
    }

    private func handle(_ action: MenuAction) {
        let text = currentSelection?.text ?? ""
        // Prototype: actions only log. The backend/LLM call will hook in here.
        NSLog("[Elo] Action selected: \(action.rawValue) | text=\"\(preview(text))\"")
        dismiss()
    }

    func dismiss() {
        panel?.orderOut(nil)
        panel = nil
        currentSelection = nil
        if let dismissMonitor {
            NSEvent.removeMonitor(dismissMonitor)
            self.dismissMonitor = nil
        }
    }

    private func preview(_ text: String) -> String {
        let trimmed = text.trimmingCharacters(in: .whitespacesAndNewlines)
        return trimmed.count > 80 ? String(trimmed.prefix(80)) + "…" : trimmed
    }
}

