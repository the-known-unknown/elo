import ApplicationServices

/// Wraps the macOS Accessibility (TCC) permission.
///
/// `isTrusted` is live OS state, not a saved setting. macOS does not notify us
/// when the user flips the toggle in System Settings, so re-read it at opportune
/// moments (e.g. when the Settings window becomes key).
enum AccessibilityManager {
    /// Whether the app is currently trusted for Accessibility.
    static var isTrusted: Bool {
        AXIsProcessTrusted()
    }

    /// Prompts for access (opening System Settings) if not already trusted.
    static func requestAccess() {
        guard !isTrusted else { return }
        let options =
            [kAXTrustedCheckOptionPrompt.takeUnretainedValue() as String: true] as CFDictionary
        _ = AXIsProcessTrustedWithOptions(options)
    }
}

