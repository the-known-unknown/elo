import AppKit

/// Wires together the long-lived services that make up Elo.
///
/// Two selection modalities (both `SelectionListener` subclasses):
///   - `MouseSelectionListener` — automatic drag-select, Accessibility-only.
///   - `HotkeyListener`         — manual ⌃⌘E, with a clipboard fallback.
///
/// Each listener calls the same handler, which shows the overlay menu.
final class AppDelegate: NSObject, NSApplicationDelegate {
    private var statusItemController: StatusItemController!
    private var listeners: [SelectionListener] = []
    private let overlayController = OverlayController()

    func applicationDidFinishLaunching(_ notification: Notification) {
        statusItemController = StatusItemController()
        statusItemController.onQuit = { NSApplication.shared.terminate(nil) }
        statusItemController.onCheckPermission = {
            AccessibilityManager.shared.requestAccessIfNeeded()
        }

        // Only prompts if the permission isn't already granted.
        AccessibilityManager.shared.requestAccessIfNeeded()

        // Both modalities share one handler: show the overlay for the selection.
        let handler: (SelectionResult) -> Void = { [weak self] selection in
            self?.overlayController.show(for: selection)
        }
        listeners = [
            MouseSelectionListener(onSelection: handler),
            HotkeyListener(onSelection: handler),
        ]
        listeners.forEach { $0.start() }

        NSLog("[Elo] Launched. Accessibility trusted: \(AccessibilityManager.shared.isTrusted)")
    }

    func applicationWillTerminate(_ notification: Notification) {
        listeners.forEach { $0.stop() }
    }
}

