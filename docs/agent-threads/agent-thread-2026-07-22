import AppKit

/// Wires together the long-lived services that make up Elo.
///
/// Approach C (hybrid) is implemented here:
///   1. Auto-detection of a selection via a global mouse monitor (Accessibility-only,
///      so it is non-invasive and never touches the clipboard automatically).
///   2. A global hotkey fallback that additionally falls back to the clipboard,
///      so it works even in apps that don't expose selection over Accessibility.
final class AppDelegate: NSObject, NSApplicationDelegate {
    private var statusItemController: StatusItemController!
    private var selectionMonitor: SelectionMonitor!
    private var hotkeyManager: HotkeyManager!
    private let overlayController = OverlayController()

    func applicationDidFinishLaunching(_ notification: Notification) {
        statusItemController = StatusItemController()
        statusItemController.onQuit = { NSApplication.shared.terminate(nil) }
        statusItemController.onCheckPermission = {
            AccessibilityManager.shared.ensureTrusted(prompt: true)
        }

        // Accessibility permission is required for both the AX read path and for
        // synthesizing keystrokes in the clipboard fallback.
        AccessibilityManager.shared.ensureTrusted(prompt: true)

        // (1) Automatic, non-invasive path: mouse drag-select -> AX read.
        selectionMonitor = SelectionMonitor { [weak self] selection in
            self?.overlayController.show(for: selection)
        }
        selectionMonitor.start()

        // (2) Manual universal fallback: ⌃⌘E -> AX read, then clipboard if needed.
        hotkeyManager = HotkeyManager { [weak self] in
            guard let self else { return }
            if let selection = SelectionReader.shared.readSelection(allowClipboardFallback: true) {
                self.overlayController.show(for: selection)
            } else {
                NSLog("[Elo] Hotkey pressed but no selection could be read.")
            }
        }
        hotkeyManager.register()

        NSLog("[Elo] Launched. Accessibility trusted: \(AccessibilityManager.shared.isTrusted)")
    }
}

