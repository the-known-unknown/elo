    }

    /// Declarative description of a single menu row.
    private struct Entry {
        enum Kind {
            case action(ItemID)  // clickable, routed through `handleItem`
            case info  // disabled label (titles, hints)
            case separator
        }

        let title: String
        let kind: Kind
        var keyEquivalent: String = ""

        static let separator = Entry(title: "", kind: .separator)
    }

    private let entries: [Entry] = [
        Entry(title: "Elo — Writing Assistant", kind: .info),
        .separator,
        Entry(title: "Check Accessibility Permission…", kind: .action(.checkPermission)),
        Entry(title: "Hotkey fallback: ⌃⌘E", kind: .info),
        .separator,
        Entry(title: "Quit Elo", kind: .action(.quit), keyEquivalent: "q"),
    ]

    init() {
        statusItem = NSStatusBar.system.statusItem(withLength: NSStatusItem.variableLength)
        if let button = statusItem.button {
            button.image = NSImage(
                systemSymbolName: "pencil.and.scribble",
                accessibilityDescription: "Elo")
            button.image?.isTemplate = true
        }
        statusItem.menu = makeMenu()
    }

    private func makeMenu() -> NSMenu {
        let menu = NSMenu()
        for entry in entries {
            menu.addItem(makeItem(for: entry))
        }
        return menu
    }

    private func makeItem(for entry: Entry) -> NSMenuItem {
        switch entry.kind {
        case .separator:
            return .separator()

        case .info:
            let item = NSMenuItem(title: entry.title, action: nil, keyEquivalent: "")
            item.isEnabled = false
            return item

        case .action(let id):
            let item = NSMenuItem(
                title: entry.title,
                action: #selector(handleItem(_:)),
                keyEquivalent: entry.keyEquivalent)
            item.target = self
            item.representedObject = id
            return item
        }
    }

    /// Single click handler for every actionable item; dispatches on the id.
    @objc private func handleItem(_ sender: NSMenuItem) {
        guard let id = sender.representedObject as? ItemID else { return }
        switch id {
        case .checkPermission: onCheckPermission?()
        case .quit: onQuit?()
        }
    }
}

