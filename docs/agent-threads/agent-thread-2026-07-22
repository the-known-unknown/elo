import AppKit
import Carbon.HIToolbox

/// Detects a "text selection" anywhere on the system and reports the result.
///
/// Recognized gestures (all on the non-invasive, Accessibility-only path, so the
/// clipboard is never touched automatically):
///   - Drag-select: mouse down -> move beyond a small threshold -> up.
///   - Double/triple-click: a click with `clickCount >= 2` selects a word/line.
///   - Select all: ⌘A.
///
/// After each gesture we ask the Accessibility API whether any text is selected;
/// if so, the overlay is shown.
final class SelectionMonitor {
    private let onSelection: (SelectionResult) -> Void
    private var monitor: Any?
    private var dragDidOccur = false
    private var mouseDownLocation: CGPoint = .zero

    /// Minimum movement (points) before a drag counts as a selection.
    private let dragThreshold: CGFloat = 3
    /// Delay before reading, so the foreground app can finalize its selection.
    private let readDelay: TimeInterval = 0.05

    init(onSelection: @escaping (SelectionResult) -> Void) {
        self.onSelection = onSelection
    }

    func start() {
        monitor = NSEvent.addGlobalMonitorForEvents(
            matching: [.leftMouseDown, .leftMouseDragged, .leftMouseUp, .keyDown]
        ) { [weak self] event in
            self?.handle(event)
        }
    }

    func stop() {
        if let monitor { NSEvent.removeMonitor(monitor) }
        monitor = nil
    }

    private func handle(_ event: NSEvent) {
        switch event.type {
        case .leftMouseDown:
            dragDidOccur = false
            mouseDownLocation = NSEvent.mouseLocation

        case .leftMouseDragged:
            let now = NSEvent.mouseLocation
            if abs(now.x - mouseDownLocation.x) > dragThreshold
                || abs(now.y - mouseDownLocation.y) > dragThreshold
            {
                dragDidOccur = true
            }

        case .leftMouseUp:
            // Trigger on a completed drag, or on a double/triple click (which
            // selects a word/line without any drag).
            if dragDidOccur || event.clickCount >= 2 {
                dragDidOccur = false
                scheduleRead()
            }

        case .keyDown:
            // Select all (⌘A). Require Command, and no other "intent" modifiers,
            // so we don't fire on shortcuts like ⌥⌘A or ⌃⌘A.
            if event.keyCode == UInt16(kVK_ANSI_A),
                event.modifierFlags.contains(.command),
                !event.modifierFlags.contains(.option),
                !event.modifierFlags.contains(.control)
            {
                scheduleRead()
            }

        default:
            break
        }
    }

    private func scheduleRead() {
        DispatchQueue.main.asyncAfter(deadline: .now() + readDelay) { [weak self] in
            guard let self, let result = SelectionReader.shared.readSelectionAXOnly() else {
                return
            }
            self.onSelection(result)
        }
    }
}

