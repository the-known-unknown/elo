import AppKit

/// Detects a "text selection gesture" anywhere on the system and reports the
/// resulting selection.
///
/// Heuristic: a left-mouse drag (down -> move beyond a small threshold -> up)
/// is treated as a selection attempt. On mouse-up we ask the Accessibility API
/// whether any text is selected. This path is intentionally AX-only so it never
/// touches the user's clipboard automatically.
final class SelectionMonitor {
    private let onSelection: (SelectionResult) -> Void
    private var monitor: Any?
    private var dragDidOccur = false
    private var mouseDownLocation: CGPoint = .zero

    /// Minimum movement (points) before a drag counts as a selection.
    private let dragThreshold: CGFloat = 3

    init(onSelection: @escaping (SelectionResult) -> Void) {
        self.onSelection = onSelection
    }

    func start() {
        monitor = NSEvent.addGlobalMonitorForEvents(
            matching: [.leftMouseDown, .leftMouseDragged, .leftMouseUp]
        ) { [weak self] event in
            self?.handle(event)
        }
    }

    func stop() {
        if let monitor { NSEvent.removeMonitor(monitor) }
        monitor = nil
    }

    private func handle(_ event: NSEvent) {
        switch event.type {
        case .leftMouseDown:
            dragDidOccur = false
            mouseDownLocation = NSEvent.mouseLocation

        case .leftMouseDragged:
            let now = NSEvent.mouseLocation
            if abs(now.x - mouseDownLocation.x) > dragThreshold ||
                abs(now.y - mouseDownLocation.y) > dragThreshold {
                dragDidOccur = true
            }

        case .leftMouseUp:
            guard dragDidOccur else { return }
            dragDidOccur = false
            // Let the foreground app finalize its selection before we read it.
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.05) { [weak self] in
                guard let self, let result = SelectionReader.shared.readSelectionAXOnly() else { return }
                self.onSelection(result)
            }

        default:
            break
        }
    }
}

